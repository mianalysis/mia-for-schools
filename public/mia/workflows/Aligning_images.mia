W_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Partners name 1" NICKNAME="Partners name 1" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Partners name 2" NICKNAME="Partners name 2" SHOW_TEXT="false" VALUE="" VISIBLE="false"/></PARAMS><PARAMS><PARAM NAME="Output type" NICKNAME="Output type" SHOW_TEXT="false" VALUE="Metadata" VISIBLE="false"/><PARAM NAME="Output image" NICKNAME="Output image" VALUE="" VISIBLE="false"/><PARAM NAME="Output objects" NICKNAME="Output objects" VALUE="" VISIBLE="false"/><PARAM NAME="Associated image" NICKNAME="Associated image" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Metadata name" NICKNAME="Metadata name" VALUE="M02" VISIBLE="false"/><PARAM NAME="Associated objects" NICKNAME="Associated objects" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Measurement name" NICKNAME="Measurement name" VALUE="" VISIBLE="false"/><PARAM NAME="Object metadata name" NICKNAME="Object metadata name" VALUE="" VISIBLE="false"/><PARAM NAME="Parent name" NICKNAME="Parent name" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Children name" NICKNAME="Children name" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Partners name 1" NICKNAME="Partners name 1" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Partners name 2" NICKNAME="Partners name 2" SHOW_TEXT="false" VALUE="" VISIBLE="false"/></PARAMS><PARAMS><PARAM NAME="Output type" NICKNAME="Output type" SHOW_TEXT="false" VALUE="Metadata" VISIBLE="false"/><PARAM NAME="Output image" NICKNAME="Output image" VALUE="" VISIBLE="false"/><PARAM NAME="Output objects" NICKNAME="Output objects" VALUE="" VISIBLE="false"/><PARAM NAME="Associated image" NICKNAME="Associated image" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Metadata name" NICKNAME="Metadata name" VALUE="M12" VISIBLE="false"/><PARAM NAME="Associated objects" NICKNAME="Associated objects" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Measurement name" NICKNAME="Measurement name" VALUE="" VISIBLE="false"/><PARAM NAME="Object metadata name" NICKNAME="Object metadata name" VALUE="" VISIBLE="false"/><PARAM NAME="Parent name" NICKNAME="Parent name" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Children name" NICKNAME="Children name" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Partners name 1" NICKNAME="Partners name 1" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Partners name 2" NICKNAME="Partners name 2" SHOW_TEXT="false" VALUE="" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER><PARAMETER NAME="Script mode" NICKNAME="Script mode" SHOW_TEXT="false" VALUE="Script text" VISIBLE="false"/><PARAMETER NAME="Script language" NICKNAME="Script language" SHOW_TEXT="false" VALUE="Beanshell" VISIBLE="false"/><PARAMETER NAME="Script text" NICKNAME="Script text" VALUE="#@ io.github.mianalysis.mia.object.Workspace workspace&#10;#@ io.github.mianalysis.mia.module.Module thisModule&#10;&#10;import io.github.mianalysis.mia.MIA;&#10;&#10;imHalfW = 256;&#10;imHalfH = 256;&#10;&#10;theta = 0;&#10;tX = imHalfW - imHalfW*Math.cos(theta) + imHalfW*Math.sin(theta) + V{TranslationX1};&#10;tY = imHalfH - imHalfH*Math.sin(theta) - imHalfH*Math.cos(theta) + V{TranslationY1};&#10;&#10;workspace.getMetadata().put(&quot;M00&quot;,Math.cos(theta));&#10;workspace.getMetadata().put(&quot;M10&quot;,Math.sin(theta));&#10;workspace.getMetadata().put(&quot;M01&quot;,-Math.sin(theta));&#10;workspace.getMetadata().put(&quot;M11&quot;,Math.cos(theta));&#10;workspace.getMetadata().put(&quot;M02&quot;,tX);&#10;workspace.getMetadata().put(&quot;M12&quot;,tY);" VISIBLE="false"/><PARAMETER NAME="Script file" NICKNAME="Script file" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Add parameter" NICKNAME="Add parameter" VALUE="" VISIBLE="false"><COLLECTION/></PARAMETER></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="M00" NICKNAME="M00"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="M01" NICKNAME="M01"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="M02" NICKNAME="M02"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="M10" NICKNAME="M10"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="M11" NICKNAME="M11"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="M12" NICKNAME="M12"/></METADATA></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.images.transform.registration.AffineFixedTransform" DISABLEABLE="false" ENABLED="true" ID="566983275" NAME="Affine (fixed transform)" NICKNAME="Affine (fixed transform)" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Input image" NICKNAME="Input image" SHOW_TEXT="false" VALUE="TransformMoving" VISIBLE="false"/><PARAMETER NAME="Apply to input image" NICKNAME="Apply to input image" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Output image" NICKNAME="Output image" VALUE="TransformMovingApplied" VISIBLE="false"/><PARAMETER NAME="Transformation" NICKNAME="Transformation" VALUE="Me{M00},Me{M10},Me{M01},Me{M11},Me{M02},Me{M12}" VISIBLE="false"/><PARAMETER NAME="Transformation message" NICKNAME="Transformation message" VALUE="Transforms are expected as comma-separated lists of 6 numbers.  These should be in the order M00, M10, M01, M11, M02, M12, where Mij is the i,jth element of the 2x3 affine transformation matrix." VISIBLE="false"/><PARAMETER NAME="Fill mode" NICKNAME="Fill mode" SHOW_TEXT="false" VALUE="Black" VISIBLE="false"/><PARAMETER NAME="Enable multithreading" NICKNAME="Enable multithreading" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.images.process.ImageCalculator" DISABLEABLE="false" ENABLED="true" ID="708247373" NAME="Image calculator" NICKNAME="Image calculator" NOTES="" SHOW_BASIC_TITLE="true" S