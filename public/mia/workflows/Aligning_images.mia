KNAME="Mirrored directory root" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Save name mode" NICKNAME="Save name mode" SHOW_TEXT="false" VALUE="Match input file/folder name" VISIBLE="false"/><PARAMETER NAME="File name" NICKNAME="File name" VALUE="" VISIBLE="false"/><PARAMETER NAME="Metadata item for grouping" NICKNAME="Metadata item for grouping" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Continuous data export" NICKNAME="Continuous data export" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Save every n files" NICKNAME="Save every n files" VALUE="10" VISIBLE="false"/><PARAMETER NAME="Append date/time mode" NICKNAME="Append date/time mode" SHOW_TEXT="false" VALUE="Never" VISIBLE="false"/><PARAMETER NAME="Export summary" NICKNAME="Export summary" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Summary mode" NICKNAME="Summary mode" SHOW_TEXT="false" VALUE="Per input file" VISIBLE="false"/><PARAMETER NAME="Metadata item for summary" NICKNAME="Metadata item for summary" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Show object counts" NICKNAME="Show object counts" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Export individual objects" NICKNAME="Export individual objects" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE></MODULES><MODULES><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.AddPathsToMetadata" DISABLEABLE="false" ENABLED="true" ID="1112629314" NAME="Add paths to metadata" NICKNAME="Add paths to metadata" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Message" NICKNAME="Message" VALUE="This module automatically adds the following metadata and global variable values:&#13;&#10;    - ImagesPath&#13;&#10;    - ThumbnailsPath&#13;&#10;    - WorkflowName&#13;&#10;    - WorkflowPath" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="ImagesPath" NICKNAME="ImagesPath"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="ThumbnailsPath" NICKNAME="ThumbnailsPath"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="WorkflowsPath" NICKNAME="WorkflowsPath"/></METADATA></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.system.GlobalVariables" DISABLEABLE="false" ENABLED="true" ID="1762540259" NAME="Global variables" NICKNAME="Global variables" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Add new variable" NICKNAME="Add new variable" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Variable name" NICKNAME="Variable name" VALUE="SSIM_Script" VISIBLE="false"/><PARAM NAME="Variable type" NICKNAME="Variable type" SHOW_TEXT="false" VALUE="Text area" VISIBLE="false"/><PARAM NAME="Variable Boolean" NICKNAME="Variable Boolean" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAM NAME="Variable value" NICKNAME="Variable value" VALUE="" VISIBLE="false"/><PARAM NAME="Variable file" NICKNAME="Variable file" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Variable folder" NICKNAME="Variable folder" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Variable choices" NICKNAME="Variable choices" VALUE="" VISIBLE="false"/><PARAM NAME="Variable choice" NICKNAME="Variable choice" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Store as metadata item" NICKNAME="Store as metadata item" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAM NAME="Variable text" NICKNAME="Variable text" VALUE="// The following two parameters will provide references to the workspace and current module.&#10;#@ io.github.mianalysis.mia.object.Workspace workspace&#10;#@ io.github.mianalysis.mia.module.Module thisModule&#10;&#10;import io.github.mianalysis.mia.MIA;&#10;&#10;import ij.process.FloatProcessor;&#10;import ij.process.ImageProcessor;&#10;&#10;mse = workspace.getImage(&quot;Difference&quot;).getMeasurement(&quot;INTENSITY // MEAN&quot;).getValue();&#10;mse_norm = 1-mse/(255*255);&#10;System.out.println(mse_norm);&#10;&#10;red_text = &quot;white&quot;;&#10;orange_box = &quot;white&quot;;&#10;amber_box = &quot;white&quot;;&#10;yellow_box = &quot;white&quot;;&#10;lime_box = &quot;white&quot;;&#10;red_shadow = &quot;&quot;;&#10;orange_shadow = &quot;&quot;;&#10;amber_shadow = &quot;&quot;;&#10;yellow_shadow = &quot;&quot;;&#10;lime_shadow = &quot;&quot;;&#10;message = &quot;Keep trying&quot;;&#10;&#10;if (mse_norm &gt; thresh1) {&#10;    red_text = &quot;red-500&quot;;&#10;    red_shadow = &quot;shadow-equal&quot;;&#10;}&#10;&#10;if (mse_norm &gt; thresh2) {&#10;    orange_box = &quot;orange-500&quot;;&#10;    orange_shadow = &quot;shadow-equal&quot;;&#10;&#9;message = &quot;That's a good start&quot;;&#10;}&#10;&#10;if (mse_norm &gt; thresh3) {&#10;    amber_box = &quot;amber-400&quot;;&#10;    amber_shadow = &quot;shadow-equal&quot;;&#10;&#9;message = &quot;Getting there&quot;;&#10;}&#10;&#10;if (mse_norm &gt; thresh4) {&#10;    yellow_box = &quot;yellow-400&quot;;  &#10;    yellow_shadow = &quot;shadow-equal&quot;; &#10;&#9;message = &quot;Almost there&quot;;&#10;}&#10;&#10;if (mse_norm &gt; thresh5) {&#10;    lime_box = &quot;lime-500&quot;;&#10;    lime_shadow = &quot;shadow-equal&quot;;&#10;&#9;message = &quot;Well done! Click \&quot;Next\&quot; when ready&quot;;&#10;}&#10;&#10;workspace.getMetadata().put(&quot;RED_BOX&quot;,red_text);&#10;workspace.getMetadata().put(&quot;ORANGE_BOX&quot;,orange_box);&#10;workspace.getMetadata().put(&quot;AMBER_BOX&quot;,amber_box);&#10;workspace.getMetadata().put(&quot;YELLOW_BOX&quot;,yellow_box);&#10;workspace.getMetadata().put(&quot;LIME_BOX&quot;,lime_box);&#10;workspace.getMetadata().put(&quot;RED_SHADOW&quot;,red_shadow);&#10;workspace.getMetadata().put(&quot;ORANGE_SHADOW&quot;,orange_shadow);&#10;workspace.getMetadata().put(&quot;AMBER_SHADOW&quot;,amber_shadow);&#10;workspace.getMetadata().put(&quot;YELLOW_SHADOW&quot;,yellow_shadow);&#10;workspace.getMetadata().put(&quot;LIME_SHADOW&quot;,lime_shadow);&#10;workspace.getMetadata().put(&quot;MESSAGE&quot;,message);&#10;" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.inputoutput.ImageLoader" DISABLEABLE="false" ENABLED="true" ID="1576128766" NAME="Load image" NICKNAME="Load image" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Output image" NICKNAME="Output image" VALUE="TN_Intro" VISIBLE="false"/><PARAMETER NAME="Import mode" NICKNAME="Import mode" SHOW_TEXT="false" VALUE="Matching format" VISIBLE="false"/><PARAMETER NAME="Reader" NICKNAME="Reader" SHOW_TEXT="false" VALUE="ImageJ" VISIBLE="false"/><PARAMETER NAME="Sequence root name" NICKNAME="Sequence root name" VALUE="" VISIBLE="false"/><PARAMETER NAME="Name format" NICKNAME="Name format" SHOW_TEXT="false" VALUE="Generic (from metadata)" VISIBLE="false"/><PARAMETER NAME="Comment" NICKNAME="Comment" VALUE="" VISIBLE="false"/><PARAMETER NAME="Extension" NICKNAME="Extension" VALUE="" VISIBLE="false"/><PARAMETER NAME="Generic format" NICKNAME="Generic format" VALUE="V{ImagesPath}V{WorkflowName}.tif" VISIBLE="false"/><PARAMETER NAME="Available metadata fields" NICKNAME="Available metadata fields" VALUE="The following metadata values are available to use for generation of a filename string.  Each metadata reference should include the &quot;M{&quot; and &quot;}&quot;:&#13;&#10;&#13;&#10;M{Extension}, M{File}, M{Filename}, M{Filepath}, M{ImagesPath}, M{Series name}, M{Series number}, M{ThumbnailsPath}, M{WorkflowsPath}&#13;&#10;&#13;&#10;Wildcard character &quot;*&quot; is also available to match variable content (first matching instance will be loaded)." VISIBLE="false"/><PARAMETER NAME="Include series number" NICKNAME="In