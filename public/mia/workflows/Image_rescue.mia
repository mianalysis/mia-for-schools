M NAME="Variable Boolean" NICKNAME="Variable Boolean" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAM NAME="Variable value" NICKNAME="AngleS{-6|6|1}" VALUE="0" VISIBLE="false"/><PARAM NAME="Variable file" NICKNAME="Variable file" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Variable folder" NICKNAME="Variable folder" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Variable choices" NICKNAME="Variable choices" VALUE="" VISIBLE="false"/><PARAM NAME="Variable choice" NICKNAME="Variable choice" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Store as metadata item" NICKNAME="Store as metadata item" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAM NAME="Variable text" NICKNAME="Variable text" VALUE="" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.script.RunScript" DISABLEABLE="false" ENABLED="true" ID="529960411" NAME="Run script" NICKNAME="Run script" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.2"><PARAMETERS><PARAMETER NAME="Script mode" NICKNAME="Script mode" SHOW_TEXT="false" VALUE="Script text" VISIBLE="false"/><PARAMETER NAME="Script language" NICKNAME="Script language" SHOW_TEXT="false" VALUE="Groovy" VISIBLE="false"/><PARAMETER NAME="Script text" NICKNAME="Script text" VALUE="// The following two parameters will provide references to the workspace and current module.&#10;#@ io.github.mianalysis.mia.object.Workspace workspace&#10;#@ io.github.mianalysis.mia.module.Module thisModule&#10;&#10;import io.github.mianalysis.mia.MIA&#10;&#10;imHalfW = 256&#10;imHalfH = 256&#10;&#10;theta = Math.toRadians(V{Theta})&#10;tX = imHalfW - imHalfW*Math.cos(theta) + imHalfW*Math.sin(theta) + V{TranslationX}&#10;tY = imHalfH - imHalfH*Math.sin(theta) - imHalfH*Math.cos(theta) + V{TranslationY}&#10;&#10;workspace.getMetadata().put(&quot;M00&quot;,Math.cos(theta))&#10;workspace.getMetadata().put(&quot;M10&quot;,Math.sin(theta))&#10;workspace.getMetadata().put(&quot;M01&quot;,-Math.sin(theta))&#10;workspace.getMetadata().put(&quot;M11&quot;,Math.cos(theta))&#10;workspace.getMetadata().put(&quot;M02&quot;,tX)&#10;workspace.getMetadata().put(&quot;M12&quot;,tY)" VISIBLE="false"/><PARAMETER NAME="Script file" NICKNAME="Script file" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Add parameter" NICKNAME="Add parameter" VALUE="" VISIBLE="false"><COLLECTION/></PARAMETER><PARAMETER NAME="Add output" NICKNAME="Add output" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Output type" NICKNAME="Output type" SHOW_TEXT="false" VALUE="Metadata" VISIBLE="false"/><PARAM NAME="Output image" NICKNAME="Output image" VALUE="" VISIBLE="false"/><PARAM NAME="Output objects" NICKNAME="Output objects" VALUE="" VISIBLE="false"/><PARAM NAME="Associated image" NICKNAME="Associated image" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Metadata name" NICKNAME="Metadata name" VALUE="M00" VISIBLE="false"/><PARAM NAME="Associated objects" NICKNAME="Associated objects" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Measurement name" NICKNAME="Measurement name" VALUE="" VISIBLE="false"/><PARAM NAME="Object metadata name" NICKNAME="Object metadata name" VALUE="" VISIBLE="false"/><PARAM NAME="Parent name" NICKNAME="Parent name" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Children name" NICKNAME="Children name" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Partners name 1" NICKNAME="Partners name 1" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Partners name 2" NICKNAME="Partners name 2" SHOW_TEXT="false" VALUE="" VISIBLE="false"/></PARAMS><PARAMS><PARAM NAME="Output type" NICKNAME="Output type" SHOW_TEXT="false" VALUE="Metadata" VISIBLE="false"/><PARAM NAME="Output image" NICKNAME="Output image" VALUE="" VISIBLE="false"/><PARAM NAME="Output objects" NICKNAME="Output objects" VALUE="" VISIBLE="false"/><PARAM 