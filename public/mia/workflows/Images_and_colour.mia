<?xml version="1.0" encoding="UTF-8"?><ROOT MIA_VERSION="1.7.26"><MODULES><MODULE CLASSNAME="io.github.mianalysis.mia.module.core.InputControl" DISABLEABLE="false" ENABLED="true" ID="1636961347222" NAME="Input control" NICKNAME="Input control" NOTES="In &quot;Input control&quot; we specify the path to the file we wish to work on.  At this point, no images are actually being loaded into the workspace.  We will load the images in during the main part of the workflow, typically using the &quot;Load image&quot; module.  These can be inserted anywhere in the workflow, meaning we're not wasting memory by opening them before they're needed.&#10;&#10;Here, we can specify a single file or, if we wish to run in batch mode, a folder.  When dealing with folders we may not want to load all the files contained within.  Therefore, it's possible to add filters that will help us process only the images of interest.  In the example here, we've got it set to only load files with .tif extensions and to skip anything with &quot;_overlay&quot; in the name (these will be created by this workflow).&#10;&#10;In MIA, parameters can be made visible for users working in &quot;Processing view&quot; by clicking the button to the right of the parameter.  In this workflow, the &quot;Input path&quot; is one such visible parameter." SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="No load message" NICKNAME="No load message" VALUE="&quot;Input control&quot; only specifies the path to the root image; no image is loaded into the workspace at this point.  To load images, add one or more &quot;Load Image&quot; modules." VISIBLE="false"/><PARAMETER NAME="Input path" NICKNAME="Input path" SHOW_TEXT="false" VALUE="V{ImagesPath}V{WorkflowName}.tif" VISIBLE="false"/><PARAMETER NAME="Series mode" NICKNAME="Series mode" SHOW_TEXT="false" VALUE="All series" VISIBLE="false"/><PARAMETER NAME="Series list" NICKNAME="Series list" VALUE="1" VISIBLE="false"/><PARAMETER NAME="Only load first file per folder" NICKNAME="Only load first file per folder" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Only load first matching group" NICKNAME="Only load first matching group" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Pattern" NICKNAME="Pattern" VALUE="" VISIBLE="false"/><PARAMETER NAME="Spatial unit" NICKNAME="Spatial unit" SHOW_TEXT="false" VALUE="Micrometres" VISIBLE="false"/><PARAMETER NAME="Temporal unit" NICKNAME="Temporal unit" SHOW_TEXT="false" VALUE="Milliseconds" VISIBLE="false"/><PARAMETER NAME="Add filter" NICKNAME="Add filter" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Filter source" NICKNAME="Filter source" SHOW_TEXT="false" VALUE="Extension" VISIBLE="false"/><PARAM NAME="Filter value" NICKNAME="Filter value" VALUE="tif" VISIBLE="false"/><PARAM NAME="Filter type" NICKNAME="Filter type" SHOW_TEXT="false" VALUE="Matches partially (include)" VISIBLE="false"/><PARAM NAME="Ignore case" NICKNAME="Ignore case" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/></PARAMS><PARAMS><PARAM NAME="Filter source" NICKNAME="Filter source" SHOW_TEXT="false" VALUE="Filename" VISIBLE="false"/><PARAM NAME="Filter value" NICKNAME="Filter value" VALUE="_overlay" VISIBLE="false"/><PARAM NAME="Filter type" NICKNAME="Filter type" SHOW_TEXT="false" VALUE="Matches partially (exclude)" VISIBLE="false"/><PARAM NAME="Ignore case" NICKNAME="Ignore case" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER><PARAMETER NAME="Simultaneous jobs" NICKNAME="Simultaneous jobs" VALUE="1" VISIBLE="false"/><PARAMETER NAME="Macro warning" NICKNAME="Macro warning" VALUE="Analysis can only be run as a single simultaneous job when ImageJ macro module is present." VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA><METADATUM EXPORT_GLOBAL="false" EXPORT_INDIVIDUAL="true" NAME="Extension" NICKNAME="Extension"/><METADATUM EXPORT_GLOBAL="false" EXPORT_INDIVIDUAL="true" NAME="File" NICKNAME="File"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="Filename" NICKNAME="Filename"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="Filepath" NICKNAME="Filepath"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="Series name" NICKNAME="Series name"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="Series number" NICKNAME="Series number"/></METADATA></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.core.OutputControl" DISABLEABLE="false" ENABLED="true" ID="1636961347222" NAME="Output control" NICKNAME="Output control" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Add variable" NICKNAME="Add variable" VALUE="" VISIBLE="false"><COLLECTION/></PARAMETER><PARAMETER NAME="Run macro" NICKNAME="Run macro" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Macro mode" NICKNAME="Macro mode" SHOW_TEXT="false" VALUE="Macro text" VISIBLE="false"/><PARAMETER NAME="Macro text" NICKNAME="Macro text" VALUE="run(&quot;Enable MIA Extensions&quot;);&#10;&#10;// Get a list of Workspace IDs with Ext.MIA_GetListOfWorkspaceIDs() and set active workspace with Ext.MIA_SetActiveWorkspace(ID)." VISIBLE="false"/><PARAMETER NAME="Macro file" NICKNAME="Macro file" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Export mode" NICKNAME="Export mode" SHOW_TEXT="false" VALUE="None" VISIBLE="false"/><PARAMETER NAME="Individual save location" NICKNAME="Individual save location" SHOW_TEXT="false" VALUE="Save with input file" VISIBLE="false"/><PARAMETER NAME="Group save location" NICKNAME="Group save location" SHOW_TEXT="false" VALUE="Save with input file" VISIBLE="false"/><PARAMETER NAME="File path" NICKNAME="File path" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Mirrored directory root" NICKNAME="Mirrored directory root" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Save name mode" NICKNAME="Save name mode" SHOW_TEXT="false" VALUE="Match input file/folder name" VISIBLE="false"/><PARAMETER NAME="File name" NICKNAME="File name" VALUE="" VISIBLE="false"/><PARAMETER NAME="Metadata item for grouping" NICKNAME="Metadata item for grouping" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Continuous data export" NICKNAME="Continuous data export" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Save every n files" NICKNAME="Save every n files" VALUE="10" VISIBLE="false"/><PARAMETER NAME="Append date/time mode" NICKNAME="Append date/time mode" SHOW_TEXT="false" VALUE="Never" VISIBLE="false"/><PARAMETER NAME="Export summary" NICKNAME="Export summary" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Summary mode" NICKNAME="Summary mode" SHOW_TEXT="false" VALUE="Per input file" VISIBLE="false"/><PARAMETER NAME="Metadata item for summary" NICKNAME="Metadata item for summary" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Show object counts" NICKNAME="Show object counts" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Export individual objects" NICKNAME="Export individual objects" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE></MODULES><MODULES><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.AddPathsToMetadata" DISABLEABLE="false" ENABLED="true" ID="1721041521326" NAME="Add paths to metadata" NICKNAME="Add paths to metadata" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Message" NICKNAME="Message" VALUE="This module automatically adds the following metadata and global variable values:&#13;&#10;    - ImagesPath&#13;&#10;    - ThumbnailsPath&#13;&#10;    - WorkflowName&#13;&#10;    - WorkflowPath" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="ImagesPath" NICKNAME="ImagesPath"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="ThumbnailsPath" NICKNAME="ThumbnailsPath"/><METADATUM EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" NAME="WorkflowsPath" NICKNAME="WorkflowsPath"/></METADATA></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.SimpleImageLoader" DISABLEABLE="false" ENABLED="true" ID="1658344828" NAME="Load image (simple)" NICKNAME="Load image (simple)" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Output image" NICKNAME="Output image" VALUE="RGB" VISIBLE="false"/><PARAMETER NAME="Import mode" NICKNAME="Import mode" SHOW_TEXT="false" VALUE="Current file" VISIBLE="false"/><PARAMETER NAME="Generic format" NICKNAME="Generic format" VALUE="" VISIBLE="false"/><PARAMETER NAME="Available metadata fields" NICKNAME="Available metadata fields" VALUE="" VISIBLE="false"/><PARAMETER NAME="Include series number" NICKNAME="Include series number" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="File path" NICKNAME="File path" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Set manual spatial calibration" NICKNAME="Set manual spatial calibration" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="XY calibration (dist/px)" NICKNAME="XY calibration (dist/px)" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Z calibration (dist/px)" NICKNAME="Z calibration (dist/px)" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Set manual temporal calibration" NICKNAME="Set manual temporal calibration" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Frame interval (time/frame)" NICKNAME="Frame interval (time/frame)" VALUE="1.0" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.SimpleImageLoader" DISABLEABLE="false" ENABLED="true" ID="834861297" NAME="Load image (simple)" NICKNAME="Load image (simple)" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Output image" NICKNAME="Output image" VALUE="Intro" VISIBLE="false"/><PARAMETER NAME="Import mode" NICKNAME="Import mode" SHOW_TEXT="false" VALUE="Generic format" VISIBLE="false"/><PARAMETER NAME="Generic format" NICKNAME="Generic format" VALUE="V{ImagesPath}V{WorkflowName}.tif" VISIBLE="false"/><PARAMETER NAME="Available metadata fields" NICKNAME="Available metadata fields" VALUE="The following metadata values are available to use for generation of a filename string.  Each metadata reference should include the &quot;M{&quot; and &quot;}&quot;:&#13;&#10;&#13;&#10;M{Extension}, M{File}, M{Filename}, M{Filepath}, M{ImagesPath}, M{Series name}, M{Series number}, M{ThumbnailsPath}, M{WorkflowsPath}&#13;&#10;&#13;&#10;Wildcard character &quot;*&quot; is also available to match variable content (first matching instance will be loaded)." VISIBLE="false"/><PARAMETER NAME="Include series number" NICKNAME="Include series number" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="File path" NICKNAME="File path" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Set manual spatial calibration" NICKNAME="Set manual spatial calibration" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="XY calibration (dist/px)" NICKNAME="XY calibration (dist/px)" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Z calibration (dist/px)" NICKNAME="Z calibration (dist/px)" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Set manual temporal calibration" NICKNAME="Set manual temporal calibration" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Frame interval (time/frame)" NICKNAME="Frame interval (time/frame)" VALUE="1.0" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.system.GUISeparator" DISABLEABLE="false" ENABLED="true" ID="1697683829" NAME="GUI separator" NICKNAME="Introduction" NOTES="The modules in this section deal with segmentation of the nuclei in 3D." SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Show in processing view" NICKNAME="Show basic" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in processing view" NICKNAME="Expanded basic GUI" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in editing view" NICKNAME="Expanded editing GUI" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.DisplayImage" DISABLEABLE="false" ENABLED="true" ID="293720879" NAME="Display image" NICKNAME="Display image" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Add image" NICKNAME="Add image" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Image name" NICKNAME="Image name" SHOW_TEXT="false" VALUE="Intro" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER><PARAMETER NAME="Show channel controls" NICKNAME="Show channel controls" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Show probe control" NICKNAME="Show probe control" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Show select control" NICKNAME="Show select control" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Show zoom control" NICKNAME="Show zoom control" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Default control" NICKNAME="Default control" SHOW_TEXT="false" VALUE="Move" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.CreateMessage" DISABLEABLE="false" ENABLED="true" ID="1313483992" NAME="Create message" NICKNAME="Create message" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Add output" NICKNAME="Add output" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Output type" NICKNAME="Output type" SHOW_TEXT="false" VALUE="Text" VISIBLE="false"/><PARAM NAME="Graph to display" NICKNAME="Graph to display" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Module" NICKNAME="Module" VALUE="" VISIBLE="false"/><PARAM NAME="Parameter to display" NICKNAME="Parameter to display" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Text to display" NICKNAME="Text to display" VALUE="We've seen how images are made of &lt;b&gt;&lt;span style=&quot;color: magenta; font-size: 1.75rem&quot;&gt;pixels&lt;/span&gt;&lt;/b&gt; and the &lt;b&gt;&lt;span style=&quot;color: lime; font-size: 1.75rem&quot;&gt;brightness&lt;/span&gt;&lt;/b&gt; of these pixels makes an image, but how do images show &lt;b&gt;&lt;span style=&quot;color: red; font-size: 1.75rem&quot;&gt;c&lt;/span&quot;&gt;&lt;span style=&quot;color: orange; font-size: 1.75rem&quot;&gt;o&lt;/span&gt;&lt;span style=&quot;color: yellow; font-size: 1.75rem&quot;&gt;l&lt;/span&gt;&lt;span style=&quot;color: green; font-size: 1.75rem&quot;&gt;o&lt;/span&gt;&lt;span style=&quot;color: blue; font-size: 1.75rem&quot;&gt;u&lt;/span&gt;&lt;span style=&quot;color: purple; font-size: 1.75rem&quot;&gt;r&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;font-size: 3rem&quot;&gt;?&lt;/span&gt;&#10;&#10;With colour images, we show &lt;b&gt;&lt;span style=&quot;color: cyan; font-size: 1.75rem&quot;&gt;three&lt;/span&gt;&lt;/b&gt; images all at once. These images show how much &lt;b&gt;&lt;span style=&quot;color: red; font-size: 1.75rem&quot;&gt;red&lt;/span&gt;&lt;/b&gt;, &lt;b&gt;&lt;span style=&quot;color: green; font-size: 1.75rem&quot;&gt;green&lt;/span&gt;&lt;/b&gt; and &lt;b&gt;&lt;span style=&quot;color: blue; font-size: 1.75rem&quot;&gt;blue&lt;/span&gt;&lt;/b&gt; is in each image.&#10;" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.system.GUISeparator" DISABLEABLE="false" ENABLED="true" ID="804064455" NAME="GUI separator" NICKNAME="Channel brightness" NOTES="The modules in this section deal with segmentation of the nuclei in 3D." SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Show in processing view" NICKNAME="Show basic" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in processing view" NICKNAME="Expanded basic GUI" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in editing view" NICKNAME="Expanded editing GUI" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.DisplayImage" DISABLEABLE="false" ENABLED="true" ID="1178028483" NAME="Display image" NICKNAME="Display image" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Add image" NICKNAME="Add image" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Image name" NICKNAME="Image name" SHOW_TEXT="false" VALUE="RGB" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER><PARAMETER NAME="Show channel controls" NICKNAME="Show channel controls" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Show probe control" NICKNAME="Show probe control" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Show select control" NICKNAME="Show select control" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Show zoom control" NICKNAME="Show zoom control" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Default control" NICKNAME="Default control" SHOW_TEXT="false" VALUE="Move" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.CreateMessage" DISABLEABLE="false" ENABLED="true" ID="1544589803" NAME="Create message" NICKNAME="Create message" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Add output" NICKNAME="Add output" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Output type" NICKNAME="Output type" SHOW_TEXT="false" VALUE="Text" VISIBLE="false"/><PARAM NAME="Graph to display" NICKNAME="Graph to display" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Module" NICKNAME="Module" VALUE="" VISIBLE="false"/><PARAM NAME="Parameter to display" NICKNAME="Parameter to display" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Text to display" NICKNAME="Text to display" VALUE="This image shows three overlapping circles.  There is one circle in each of the red, green and blue channels.  &#10;&#10;By moving the sliders below the image, you can change how much red, green and blue is shown.  &#10;&#10;Can you move the sliders to make new colours?  How about orange or purple?" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.system.GUISeparator" DISABLEABLE="false" ENABLED="true" ID="659321289" NAME="GUI separator" NICKNAME="Channel brightness" NOTES="The modules in this section deal with segmentation of the nuclei in 3D." SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Show in processing view" NICKNAME="Show basic" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in processing view" NICKNAME="Expanded basic GUI" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in editing view" NICKNAME="Expanded editing GUI" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.DisplayImage" DISABLEABLE="false" ENABLED="true" ID="1695350852" NAME="Display image" NICKNAME="Display image" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Add image" NICKNAME="Add image" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Image name" NICKNAME="Image name" SHOW_TEXT="false" VALUE="RGB" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER><PARAMETER NAME="Show channel controls" NICKNAME="Show channel controls" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Show probe control" NICKNAME="Show probe control" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Show select control" NICKNAME="Show select control" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Show zoom control" NICKNAME="Show zoom control" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Default control" NICKNAME="Default control" SHOW_TEXT="false" VALUE="Move" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.DisplayGraph" DISABLEABLE="false" ENABLED="false" ID="53464303" NAME="Display graph" NICKNAME="Display graph" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Graph source" NICKNAME="Graph source" SHOW_TEXT="false" VALUE="Channel components" VISIBLE="false"/><PARAMETER NAME="Input objects" NICKNAME="Input objects" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Object measurement" NICKNAME="Object measurement" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Range minimum" NICKNAME="Range minimum" VALUE="0.0" VISIBLE="false"/><PARAMETER NAME="Range maximum" NICKNAME="Range maximum" VALUE="100.0" VISIBLE="false"/><PARAMETER NAME="Number of bins" NICKNAME="Number of bins" VALUE="10" VISIBLE="false"/><PARAMETER NAME="Graph type" NICKNAME="Graph type" SHOW_TEXT="false" VALUE="Pie" VISIBLE="false"/><PARAMETER NAME="Show data labels" NICKNAME="Show data labels" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="X-axis label" NICKNAME="X-axis label" VALUE="" VISIBLE="false"/><PARAMETER NAME="Y-axis label" NICKNAME="Y-axis label" VALUE="" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.miaserver.modules.CreateMessage" DISABLEABLE="false" ENABLED="true" ID="76578111" NAME="Create message" NICKNAME="Create message" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Add output" NICKNAME="Add output" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Output type" NICKNAME="Output type" SHOW_TEXT="false" VALUE="Text" VISIBLE="false"/><PARAM NAME="Graph to display" NICKNAME="Graph to display" SHOW_TEXT="false" VALUE="TastyPie" VISIBLE="false"/><PARAM NAME="Module" NICKNAME="Module" VALUE="" VISIBLE="false"/><PARAM NAME="Parameter to display" NICKNAME="Parameter to display" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAM NAME="Text to display" NICKNAME="Text to display" VALUE="As you move the sliders, we can measure how much of the image is red, green or blue.&#10;&#10;To be continued..." VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE></MODULES></ROOT>