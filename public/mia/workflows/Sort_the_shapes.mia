lse" VALUE="" VISIBLE="false"/><PARAM NAME="Text to display" NICKNAME="Text to display" VALUE="&lt;span class=&quot;text-emerald-500 italic text-5xl&quot;&gt;About&lt;/span&gt;&lt;span style=&quot;display: block; margin-bottom: 0.3rem;&quot;&gt;&lt;/span&gt;&lt;br&gt;We can teach computers to recognise patterns.  This is called &quot;machine learning&quot;, which is a type of &quot;artificial intelligence&quot; or &quot;AI&quot;&lt;br&gt;&lt;br&gt;Using this, we can sort things based on how they look&lt;br&gt;&lt;br&gt;For this, we often use properties like shape, size and colour&lt;/span&gt;." VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.system.GUISeparator" DISABLEABLE="false" ENABLED="true" ID="1969647242" NAME="GUI separator" NICKNAME="Intro to activity" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Show in processing view" NICKNAME="Show in processing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in processing view" NICKNAME="Expanded in processing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Expanded in editing view" NICKNAME="Expanded in editing view" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS/><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.images.transform.ExtractSubstack" DISABLEABLE="false" ENABLED="true" ID="1843062819" NAME="Extract substack" NICKNAME="Extract substack" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.0"><PARAMETERS><PARAMETER NAME="Input image" NICKNAME="Input image" SHOW_TEXT="false" VALUE="Intro" VISIBLE="false"/><PARAMETER NAME="Output image" NICKNAME="Output image" VALUE="Intro2" VISIBLE="false"/><PARAMETER NAME="Selection mode" NICKNAME="Selection mode" SHOW_TEXT="false" VALUE="Fixed" VISIBLE