ToOne" DISABLEABLE="false" ENABLED="true" ID="1118971057" NAME="Relate many-to-one" NICKNAME="Relate many-to-one" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.1.0"><PARAMETERS><PARAMETER NAME="Parent (larger) objects" NICKNAME="Parent (larger) objects" SHOW_TEXT="false" VALUE="Diatoms1" VISIBLE="false"/><PARAMETER NAME="Child (smaller) objects" NICKNAME="Child (smaller) objects" SHOW_TEXT="false" VALUE="Click" VISIBLE="false"/><PARAMETER NAME="Method to relate objects" NICKNAME="Method to relate objects" SHOW_TEXT="false" VALUE="Spatial overlap" VISIBLE="false"/><PARAMETER NAME="Reference mode" NICKNAME="Reference mode" SHOW_TEXT="false" VALUE="Centroid" VISIBLE="false"/><PARAMETER NAME="Linking distance limit" NICKNAME="Linking distance limit" SHOW_TEXT="false" VALUE="No limit" VISIBLE="false"/><PARAMETER NAME="Maximum linking distance (px)" NICKNAME="Maximum linking distance (px)" VALUE="1.0" VISIBLE="false"/><PARAMETER NAME="Inside/outside mode" NICKNAME="Inside/outside mode" SHOW_TEXT="false" VALUE="Inside and outside (all distances)" VISIBLE="false"/><PARAMETER NAME="Minimum overlap (%)" NICKNAME="Minimum overlap (%)" VALUE="0.0" VISIBLE="false"/><PARAMETER NAME="Require centroid overlap" NICKNAME="Require centroid overlap" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Only link objects in same frame" NICKNAME="Only link objects in same frame" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Calculate fractional distance" NICKNAME="Calculate fractional distance" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Ignore XY edges" NICKNAME="Ignore XY edges" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Ignore Z edges" NICKNAME="Ignore Z edges" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/><PARAMETER NAME="Enable multithreading" NICKNAME="Enable multithreading" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Show objects" NICKNAME="Show objects" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAMETER NAME="Show measurements" NICKNAME="Show measurements" SHOW_TEXT="false" VALUE="false" VISIBLE="false"/></PARAMETERS><IMAGE_MEASUREMENTS/><OBJECT_MEASUREMENTS><MEASUREMENT EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" EXPORT_MAX="true" EXPORT_MEAN="true" EXPORT_MIN="true" EXPORT_STD="true" EXPORT_SUM="true" NAME="RELATE_MANY_TO_ONE // OVERLAP_WITH_Diatoms1_PERCENTAGE" NICKNAME="RELATE_MANY_TO_ONE // OVERLAP_WITH_Diatoms1_PERCENTAGE" OBJECT_NAME="Click"/><MEASUREMENT EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" EXPORT_MAX="true" EXPORT_MEAN="true" EXPORT_MIN="true" EXPORT_STD="true" EXPORT_SUM="true" NAME="RELATE_MANY_TO_ONE // WAS_LINKED_Click" NICKNAME="RELATE_MANY_TO_ONE // WAS_LINKED_Click" OBJECT_NAME="Diatoms1"/><MEASUREMENT EXPORT_GLOBAL="true" EXPORT_INDIVIDUAL="true" EXPORT_MAX="true" EXPORT_MEAN="true" EXPORT_MIN="true" EXPORT_STD="true" EXPORT_SUM="true" NAME="RELATE_MANY_TO_ONE // WAS_LINKED_Diatoms1" NICKNAME="RELATE_MANY_TO_ONE // WAS_LINKED_Diatoms1" OBJECT_NAME="Click"/></OBJECT_MEASUREMENTS><METADATA/></MODULE><MODULE CLASSNAME="io.github.mianalysis.mia.module.script.RunScript" DISABLEABLE="false" ENABLED="true" ID="980833182" NAME="Run script" NICKNAME="Run script" NOTES="" SHOW_BASIC_TITLE="true" SHOW_OUTPUT="false" VERSION="1.0.2"><PARAMETERS><PARAMETER NAME="Script mode" NICKNAME="Script mode" SHOW_TEXT="false" VALUE="Script text" VISIBLE="false"/><PARAMETER NAME="Script language" NICKNAME="Script language" SHOW_TEXT="false" VALUE="Groovy" VISIBLE="false"/><PARAMETER NAME="Script text" NICKNAME="Script text" VALUE="// The following two parameters will provide references to the workspace and current module.&#10;#@ io.github.mianalysis.mia.object.Workspace workspace&#10;#@ io.github.mianalysis.mia.module.Module thisModule&#10;&#10;import io.github.mianalysis.mia.MIA&#10;import io.github.mianalysis.mia.object.ObjMetadata&#10;&#10;diatoms = workspace.getObjects(&quot;Diatoms1&quot;)&#10;&#10;for (diatom:diatoms.values()) {&#10;&#9;currMetadataItem = diatom.getMetadataItem(&quot;CLASS&quot;)&#10;&#10;&#9;if (diatom.getChildren(&quot;Click&quot;).size() == 0) {&#10;&#9;&#9;if (currMetadataItem == null) {&#10;&#9;&#9;&#9;diatom.addMetadataItem(new ObjMetadata(&quot;CLASS&quot;, &quot;&quot;));&#10;&#9;&#9;&#9;diatom.addMetadataItem(new ObjMetadata(&quot;CLASS_SHORT&quot;, &quot;&quot;));&#10;&#9;&#9;}&#10;&#10;&#9;&#9;continue&#10;&#10;&#9;}&#10;&#10;&#9;currMetadataItem = diatom.getMetadataItem(&quot;CLASS&quot;)&#10;&#9;if (currMetadataItem == null) {&#10;&#9;&#9;diatom.addMetadataItem(new ObjMetadata(&quot;CLASS&quot;, currClass));&#10;&#9;&#9;diatom.addMetadataItem(new ObjMetadata(&quot;CLASS_SHORT&quot;, currClass.substring(0,1)));&#10;&#9;} else if (currMetadataItem.getValue().equals(currClass)) {&#10;&#9;&#9;diatom.removeMetadataItem(&quot;CLASS&quot;)&#10;&#9;&#9;diatom.removeMetadataItem(&quot;CLASS_SHORT&quot;)&#10;&#9;} else {&#10;&#9;&#9;diatom.addMetadataItem(new ObjMetadata(&quot;CLASS&quot;, currClass));&#10;&#9;&#9;diatom.addMetadataItem(new ObjMetadata(&quot;CLASS_SHORT&quot;, currClass.substring(0,1)));&#10;    }&#10;}" VISIBLE="false"/><PARAMETER NAME="Script file" NICKNAME="Script file" SHOW_TEXT="false" VALUE="" VISIBLE="false"/><PARAMETER NAME="Add parameter" NICKNAME="Add parameter" VALUE="" VISIBLE="false"><COLLECTION><PARAMS><PARAM NAME="Parameter type" NICKNAME="Parameter type" SHOW_TEXT="false" VALUE="Text" VISIBLE="false"/><PARAM NAME="Parameter name" NICKNAME="Parameter name" VALUE="currClass" VISIBLE="false"/><PARAM NAME="Parameter checkbox" NICKNAME="Parameter checkbox" SHOW_TEXT="false" VALUE="true" VISIBLE="false"/><PARAM NAME="Parameter numeric value" NICKNAME="Parameter numeric value" VALUE="0.0" VISIBLE="false"/><PARAM NAME="Parameter text value" NICKNAME="Parameter text value" VALUE="V{CurrClass}" VISIBLE="false"/></PARAMS></COLLECTION></PARAMETER><PARAMETER NAME="Add output" NICKNAME="Add output" VALUE="" VISIBLE="false"><COLLECTI